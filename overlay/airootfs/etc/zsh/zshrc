# claude-rescue zshrc

# Source profile.d (zsh doesn't do this automatically)
for f in /etc/profile.d/*.sh; do [[ -r "$f" ]] && source "$f"; done
unset f

# History
HISTFILE=/root/.zsh_history
HISTSIZE=1000
SAVEHIST=1000
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE SHARE_HISTORY

# Completion
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
setopt AUTO_CD

# Prompt: red root indicator, hostname, path
autoload -Uz colors && colors
PROMPT="%{$fg_bold[red]%}[rescue]%{$reset_color%} %{$fg[cyan]%}%~%{$reset_color%} # "

# Useful aliases
alias ls='ls --color=auto'
alias ll='ls -lah'
alias df='df -h'
alias free='free -h'
alias dmesg='dmesg --color=always'
alias rescue='[[ -x /usr/local/bin/rescue ]] && /usr/local/bin/rescue || echo "rescue launcher not yet installed"'
